rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is the authenticated owner of the restaurant
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Restaurant profile rules
    match /users/{userId} {
      // Allow anyone to read the restaurant profile (needed for customer menu, currency, theme, etc.)
      allow read: if true;
      // Only the authenticated restaurant owner can modify the restaurant profile
      allow write: if isOwner(userId);

      // Private Settings (Contains Stripe and Iyzico Secret Keys)
      // Strictly restricted to the authenticated restaurant owner only!
      match /privateSettings/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Staff subcollection (Contains staff usernames and password hashes)
      // Strictly restricted to the authenticated restaurant owner only!
      // Staff authentication is handled securely server-side via /api/staffLogin
      match /staff/{staffId} {
        allow read, write: if isOwner(userId);
      }

      // Menu Items (Readable by customers, writeable only by owner)
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Branches (Readable by customers, writeable only by owner)
      match /branches/{branchId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Coupons (Readable by customers, writeable only by owner)
      match /coupons/{couponId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Stock Management (Readable and updateable by customers for stock deduction, managed by owner)
      match /stock/{stockId} {
        allow read, update: if true;
        allow create, delete: if isOwner(userId);
      }

      // Orders (Customers can create/track, KDS/Staff panel can read/update)
      match /orders/{orderId} {
        allow create: if true;
        allow get: if true;
        // Allowed for unauthenticated KDS and Staff panels to function properly
        allow list, update: if true;
        allow delete: if isOwner(userId);
      }

      // Waiter Calls (Customers can create, Staff panel can read/update)
      match /calls/{callId} {
        allow create: if true;
        allow read, update: if true;
        allow delete: if isOwner(userId);
      }

      // Feedback (Customers can create, owner can read)
      match /feedback/{feedbackId} {
        allow create: if true;
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
